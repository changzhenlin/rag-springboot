APP_NAME=rag-python-service
APP_HOST=0.0.0.0
SERVER_PORT=8080
CORS_ORIGINS=*

DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_CHAT_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_TEMPERATURE=0.7

VECTOR_BACKEND=auto
LOCAL_VECTOR_STORE_PATH=data/local_vector_store.json

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=rag_documents
MILVUS_DIMENSION=1536
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_METRIC_TYPE=COSINE

CHUNK_SIZE=1000
CHUNK_OVERLAP=120
