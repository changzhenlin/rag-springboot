# ===========================================
# 阿里云百炼 DashScope API 配置
# ===========================================
# 获取地址：https://dashscope.console.aliyun.com/
# 在控制台开通 DashScope 服务并创建 API Key

DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ===========================================
# Milvus 向量数据库配置（可选，默认值如下）
# ===========================================
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_USERNAME=
# MILVUS_PASSWORD=

# ===========================================
# 其他环境变量
# ===========================================
# 服务器端口（可选）
# SERVER_PORT=8080
